# ===============================================
# FAHAMU SHAMBA - ENVIRONMENT CONFIGURATION TEMPLATE
# ===============================================
# For Local Development: Use sqlite (DATABASE_URL not needed)
# For Render Production: DATABASE_URL is auto-set to PostgreSQL

## ENVIRONMENT & DEBUG
FLASK_ENV=production
DEBUG=false
LOG_LEVEL=INFO

## DATA STORAGE
DB_PATH=fahamu_shamba.db
MODEL_DATA_DIR=.
MODEL_PATH=enhanced_crop_recommendation_model.pkl
TRAINING_DATA_PATH=fahamu_shamba_training_data.csv

## SECURITY
SECRET_KEY=replace_with_a_long_random_secret_minimum_32_chars
FAHAMU_API_KEY=replace_with_internal_service_api_key

## OPENAI API (For enhanced AI responses)
OPENAI_API_KEY=sk_replace_with_your_openai_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=25

## TWILIO (Voice IVR & SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

## AFRICA'S TALKING (USSD & SMS)
AFRICASTALKING_USERNAME=Sandbox
AFRICASTALKING_API_KEY=atsk_replace_with_your_api_key

## WEATHER & REAL-TIME DATA
OPENWEATHER_API_KEY=replace_with_openweather_api_key

## SERVICE URLs
DATA_SERVICE_URL=http://localhost:5007

## CHATBOT SETTINGS
ALLOWED_ORIGINS=https://your-production-domain.example
RATE_LIMIT_PER_MINUTE=60
MAX_RESPONSE_LENGTH=500
MAX_MESSAGE_LENGTH=1000
CONFIDENCE_THRESHOLD=0.3
